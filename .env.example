# ── Environment ──
PORT=3000
JWT_SECRET=change_me_to_a_secure_random_string_32_chars
REDIS_URL=redis://redis_cache:6379
ALLOWED_ORIGINS=http://localhost:5173

# ── LLM Configuration ──
# LLM Provider selection: 'openai' or 'gemini'
LLM_PROVIDER=gemini

# Optional: Override the default model name
# Defaults: 'gpt-4o-mini' for openai, 'gemini-2.0-flash' for gemini
# LLM_MODEL=gemini-2.0-flash

# API Keys (Provide the key corresponding to your selected LLM_PROVIDER)
OPENAI_API_KEY=
GEMINI_API_KEY=

